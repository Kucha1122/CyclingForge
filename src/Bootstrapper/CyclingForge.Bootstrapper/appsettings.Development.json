{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "ConnectionStrings": {
    "UsersDb": "Server=(localdb)\\mssqllocaldb;Database=CyclingForge_Users;Trusted_Connection=True;MultipleActiveResultSets=true",
    "StravaDb": "Server=(localdb)\\mssqllocaldb;Database=CyclingForge_Strava;Trusted_Connection=True;MultipleActiveResultSets=true",
    "ActivitiesDb": "Server=(localdb)\\mssqllocaldb;Database=CyclingForge_Activities;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Auth": {
    "Issuer": "CyclingForge",
    "Audience": "CyclingForge",
    "SigningKey": "CHANGE_THIS_TO_A_SECURE_KEY_AT_LEAST_32_CHARS_LONG!!",
    "ExpiryMinutes": 120
  },
  "Strava": {
    "ClientId": "YOUR_STRAVA_CLIENT_ID",
    "ClientSecret": "YOUR_STRAVA_CLIENT_SECRET",
    "RedirectUri": "https://localhost:5001/api/strava/callback"
  }
}
